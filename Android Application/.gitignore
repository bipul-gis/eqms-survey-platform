# Node
node_modules/

# Capacitor: the web copy is regenerated every build, no need to track it.
www/

# Android build artifacts (generated by Gradle / Android Studio).
android/build/
android/app/build/
android/.gradle/
android/.idea/
android/local.properties
android/captures/
android/app/release/
android/app/debug/
android/keystore.properties

# Generated APKs / AABs end up here — useful as a staging spot but huge,
# so they're tracked outside git (drop them in your release-channel of choice).
*.apk
*.aab
release-artifacts/

# Keystore — NEVER commit. Keep this file in three offline backups; lose
# it and you can no longer update sideloaded installs.
*.jks
*.keystore

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
