# EQMS GeoSurvey — environment (copy to .env)

# PostgreSQL (VPS: eqms-geosurvey database)
DATABASE_URL=postgresql://geosurvey:YOUR_PASSWORD@127.0.0.1:5432/eqms_geosurvey
DATABASE_SSL=false
PORT=3002

# Default password for migrated users / password reset
DEFAULT_GEOSURVEY_PASSWORD=admin123

# Admin emails (comma-separated) — always get admin + approved
ADMIN_EMAILS=bipul.paul@eqmscl.com,admin@ccc.gov.bd

# MIS project list (direct read from MIS PostgreSQL; no MIS login required)
MIS_DATABASE_URL=postgresql://eqms:YOUR_MIS_PASSWORD@127.0.0.1:5432/eqms-mis

# Optional extra CORS origins (comma-separated)
# CORS_ORIGINS=https://geosurvey.eqmscl.com

# Firebase migration (scripts/migrate-firebase-to-pg.ts)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json
# FIRESTORE_DATABASE_ID=ai-studio-9ec2ba62-8eec-4c14-9866-fbc956d9997c

# Frontend (Vite) — leave empty in production (same-origin /api)
# VITE_API_BASE_URL=http://127.0.0.1:3002
