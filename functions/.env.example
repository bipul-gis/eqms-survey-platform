# Auto-generated: `firebase deploy` runs `scripts/inject-functions-env.cjs` first, which
# copies `apiKey` from the repo root `firebase-applet-config.json` into this file.
# You can create `.env` locally for the emulator, or run:
#   node functions/scripts/inject-functions-env.cjs
#
# WEB_API_KEY=   (same as web app apiKey; inject script writes this — do not use FIREBASE_* prefix in .env)
#
# Optional: only if your `users` collection is in a non-default database (and your web app
# uses getFirestore(app, 'that-id')).
# FIRESTORE_DATABASE_ID=
